# =============================================================================
# Pick ONE broker by setting BROKER below, then fill in only that broker's keys.
# Default is alpaca. UK users may prefer paperinvest (no KYC, fast signup).
# =============================================================================

BROKER=alpaca   # alpaca | paperinvest

# --- REQUIRED FOR ALL BROKERS ---

# OpenAI API key.
# 1. Sign up at https://platform.openai.com/
# 2. Add a small amount of credit ($5–10 is plenty to start)
# 3. Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=


# --- BROKER: alpaca ---
# 1. Sign up at https://app.alpaca.markets/signup
# 2. Switch to "Paper Trading" in the dashboard (top-left dropdown)
# 3. Generate a new key — paste both values below
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# This MUST be the paper URL. The agent refuses to start otherwise.
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# --- BROKER: paperinvest ---
# 1. Sign up at https://paperinvest.io/ (no KYC, takes ~1 minute)
# 2. Go to app.paperinvest.io → Settings → API Keys → Create
# 3. Copy the api_key_... value into PAPERINVEST_API_KEY
# 4. Find your portfolio + account IDs under Portfolio Management
PAPERINVEST_API_KEY=
PAPERINVEST_PORTFOLIO_ID=
PAPERINVEST_ACCOUNT_ID=


# --- OPTIONAL ---

# LLM model. gpt-5-mini recommended (cheap, fast, good rate limits).
# Other options: gpt-5, gpt-4o, gpt-4o-mini
MODEL=gpt-5-mini

# Profile name for log/data file isolation. Leave alone unless you know why.
PROFILE_NAME=gpt5mini

# Dashboard port (http://localhost:3737)
DASHBOARD_PORT=3737
